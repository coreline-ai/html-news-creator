# Core
APP_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_trend
REPORT_PUBLIC_BASE_URL=http://localhost:3000

# docker-compose 컨테이너 비밀번호. .env 미설정 시 위 기본값과 동일하게 동작.
# 노트북 도난·우발적 노출 방어를 위해 로컬 .env 에서 강한 비밀번호로 덮어쓸 것.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_trend
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# LLM
OPENAI_API_KEY=local-proxy
OPENAI_BASE_URL=http://127.0.0.1:4317/openai/v1
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Web extraction
FIRECRAWL_API_KEY=
CRAWL4AI_ENABLED=true
TRAFILATURA_ENABLED=true

# Supabase optional
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub
GITHUB_TOKEN=
# true이면 GITHUB_TOKEN 없이도 낮은 한도 anonymous API fallback을 시도한다.
GITHUB_ALLOW_UNAUTHENTICATED=true

# X/Twitter optional
X_BEARER_TOKEN=
X_ENABLED=false

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-trend-assets
S3_REGION=us-east-1

# Deploy
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# Runtime
TIMEZONE=Asia/Seoul
LOG_LEVEL=info
MAX_SOURCES_PER_RUN=500
MAX_IMAGES_PER_RUN=50
GENERATED_IMAGE_FALLBACK_ENABLED=true
