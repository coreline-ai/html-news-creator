<article class="section-card" style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; margin-bottom: 24px;">
  {% set images = section.content_image_urls if section.content_image_urls else ([section.og_image_url] if section.og_image_url else []) %}
  {% set youtube = namespace(found=false) %}
  {% for source in section.sources_json | default([]) %}
    {% set source_url = source.url | default('', true) %}
    {% if source.video_id | default('', true) or 'youtube.com/watch' in source_url or 'youtu.be/' in source_url or 'youtube.com/shorts' in source_url %}
      {% set youtube.found = true %}
    {% endif %}
  {% endfor %}
  {% if images %}
  {% set article_url = section.sources_json[0].url if section.sources_json else '#' %}
  {% if images | length == 1 %}
  <a href="{{ article_url }}" target="_blank" rel="noopener noreferrer" style="position: relative; display: block;">
    <img src="{{ images[0] }}" alt="{{ section.title | default('') }}"
         style="width: 100%; max-height: 320px; object-fit: cover; display: block;"
         onerror="this.parentElement.style.display='none'">
    {% if youtube.found %}
    <span class="youtube-play-overlay" aria-hidden="true" style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 64px; height: 64px; border-radius: 9999px; background: rgba(15, 23, 42, 0.72); box-shadow: 0 10px 24px rgba(15, 23, 42, 0.24); display: flex; align-items: center; justify-content: center; pointer-events: none;">
      <span style="display: block; width: 0; height: 0; border-top: 15px solid transparent; border-bottom: 15px solid transparent; border-left: 22px solid white; margin-left: 5px;"></span>
    </span>
    {% endif %}
  </a>
  {% else %}
  <div style="display: grid; grid-template-columns: repeat({{ [images|length, 3]|min }}, 1fr); gap: 2px;">
    {% for img_url in images[:3] %}
    <a href="{{ article_url }}" target="_blank" rel="noopener noreferrer" style="position: relative; display: block;">
      <img src="{{ img_url }}" alt="{{ section.title | default('') }} {{ loop.index }}"
           style="width: 100%; height: 200px; object-fit: cover; display: block;"
           onerror="this.parentElement.style.display='none'">
      {% if youtube.found %}
      <span class="youtube-play-overlay" aria-hidden="true" style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 52px; height: 52px; border-radius: 9999px; background: rgba(15, 23, 42, 0.72); box-shadow: 0 8px 18px rgba(15, 23, 42, 0.22); display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <span style="display: block; width: 0; height: 0; border-top: 12px solid transparent; border-bottom: 12px solid transparent; border-left: 18px solid white; margin-left: 4px;"></span>
      </span>
      {% endif %}
    </a>
    {% endfor %}
  </div>
  {% endif %}
  {% endif %}
  <div style="padding: 24px;">
  <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px;">
    <h3 style="font-size: 1.125rem; font-weight: 600; flex: 1;">{{ section.title | default('') }}</h3>
    {% if section.verification_status == 'official_confirmed' %}
    <span style="background: var(--color-official); color: white; font-size: 0.75rem; font-weight: 600; padding: 2px 10px; border-radius: 9999px; white-space: nowrap;">공식 확인</span>
    {% elif section.verification_status == 'unverified' %}
    <span style="background: var(--color-unverified); color: white; font-size: 0.75rem; font-weight: 600; padding: 2px 10px; border-radius: 9999px; white-space: nowrap;">미검증</span>
    {% endif %}
  </div>

  {% if section.summary_ko %}
  <p style="color: #475569; margin-bottom: 16px;">{{ section.summary_ko }}</p>
  {% endif %}

  {% if section.fact_summary %}
  <div style="background: #f0fdf4; border-left: 4px solid var(--color-official); border-radius: 4px; padding: 12px 16px; margin-bottom: 12px;">
    <div style="font-size: 0.75rem; font-weight: 700; color: #15803d; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">팩트</div>
    <p style="font-size: 0.9rem; color: #166534;">{{ section.fact_summary }}</p>
  </div>
  {% endif %}

  {% if section.social_signal_summary %}
  <div style="background: #eff6ff; border-left: 4px solid var(--color-accent); border-radius: 4px; padding: 12px 16px; margin-bottom: 12px;">
    <div style="font-size: 0.75rem; font-weight: 700; color: #1d4ed8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">소셜 신호</div>
    <p style="font-size: 0.9rem; color: #1e3a8a;">{{ section.social_signal_summary }}</p>
  </div>
  {% endif %}

  {% if section.inference_summary %}
  <div style="background: #fff7ed; border-left: 4px solid var(--color-unverified); border-radius: 4px; padding: 12px 16px; margin-bottom: 12px;">
    <div style="font-size: 0.75rem; font-weight: 700; color: #b45309; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">⚠️ 추론</div>
    <p style="font-size: 0.9rem; color: #92400e;">{{ section.inference_summary }}</p>
  </div>
  {% endif %}

  {% if section.sources_json %}
  <div style="margin-top: 16px; border-top: 1px solid var(--color-border); padding-top: 12px;">
    <div style="font-size: 0.75rem; font-weight: 600; color: #64748b; margin-bottom: 8px;">출처</div>
    <ul style="list-style: none; display: flex; flex-wrap: wrap; gap: 8px;">
      {% for source in section.sources_json %}
      <li>
        {% if source.url %}
        <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer"
           style="font-size: 0.8rem; color: var(--color-accent); text-decoration: none; background: #eff6ff; padding: 2px 8px; border-radius: 4px; border: 1px solid #bfdbfe;">
          {{ source.name | default(source.url) }}
        </a>
        {% else %}
        <span style="font-size: 0.8rem; color: #64748b; background: #f1f5f9; padding: 2px 8px; border-radius: 4px; border: 1px solid var(--color-border);">
          {{ source.name | default('') }}
        </span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  </div>{# /padding div #}
</article>
